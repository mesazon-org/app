{
    "build": {
      "development": {
        "developmentClient": true,
        "distribution": "internal",
        "ios": {
            "simulator": true
        },
        "env": {
            "APP_VARIANT": "development"
        }
      },
      "ios-simulator": {
        "extends": "development",
        "ios": {
            "simulator": true
        }
      },
      "preview": {
        "distribution": "internal",
        "env": {
            "APP_VARIANT": "preview"
        }
      },
      "production": {
        "autoIncrement": true
      }
    }
  }
  