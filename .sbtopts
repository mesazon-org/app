# Memory for the sbt server JVM.
-J-Xmx8G
-J-Xms4G

# GC: keep the sbt shell responsive.
-J-XX:+UseG1GC
-J-XX:MaxGCPauseMillis=200
-J-XX:+UseStringDeduplication

# Force ANSI colour on regardless of the client's TTY detection (sbt 2's thin client
# otherwise drops colour in some terminals). GitHub Actions renders ANSI, so CI is unaffected.
-Dsbt.color=always
